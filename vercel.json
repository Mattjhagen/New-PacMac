{
  "version": 2,
  "name": "pacmac-mobile-unified",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/splash",
      "dest": "/splash"
    },
    {
      "src": "/admin",
      "dest": "/admin"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}